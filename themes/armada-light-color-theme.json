  "tokenColors": [
    {
      "metadata": {
        "description": "Comments"
      },
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#747576"
      }
    },
    {
      "metadata": {
        "description": "Strings"
      },
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#086E14"
      }
    },
    {
      "metadata": {
        "description": "String escapes"
      },
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "foreground": "#A31D8D"
      }
    },
    {
      "metadata": {
        "description": "Numbers"
      },
      "scope": [
        "constant.numeric",
        "constant.character"
      ],
      "settings": {
        "foreground": "#A31D8D"
      }
    },
    {
      "metadata": {
        "description": "Language constants"
      },
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#A31D8D"
      }
    },
    {
      "metadata": {
        "description": "Keywords"
      },
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#14646E"
      }
    },
    {
      "metadata": {
        "description": "Operators"
      },
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#090909"
      }
    },
    {
      "metadata": {
        "description": "Function calls"
      },
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#5511BF"
      }
    },
    {
      "metadata": {
        "description": "Function declarations only (not constructors / patterns inside meta.function)"
      },
      "scope": [
        "meta.definition.function entity.name.function",
        "meta.function.definition entity.name.function",
        "entity.name.function.definition"
      ],
      "settings": {
        "foreground": "#090909",
        "fontStyle": ""
      }
    },
    {
      "metadata": {
        "description": "Classes / types"
      },
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.class",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#1749BD"
      }
    },
    {
      "metadata": {
        "description": "Properties / fields"
      },
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#A31D8D"
      }
    },
    {
      "metadata": {
        "description": "Variables"
      },
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#090909"
      }
    },
    {
      "metadata": {
        "description": "Constants / enums"
      },
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant"
      ],
      "settings": {
        "foreground": "#A31D8D"
      }
    },
    {
      "metadata": {
        "description": "Decorators / annotations / metadata"
      },
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator",
        "meta.annotation",
        "punctuation.definition.annotation",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#616605"
      }
    },
    {
      "metadata": {
        "description": "Tags"
      },
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#B0B0B0"
      }
    },
    {
