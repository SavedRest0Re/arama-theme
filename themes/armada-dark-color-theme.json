  "tokenColors": [
    {
      "metadata": {
        "description": "Comments"
      },
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#909194"
      }
    },
    {
      "metadata": {
        "description": "Strings"
      },
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#E394DC"
      }
    },
    {
      "metadata": {
        "description": "String escapes"
      },
      "scope": [
        "constant.character.escape",
        "string.escape"
      ],
      "settings": {
        "foreground": "#82D2CE"
      }
    },
    {
      "metadata": {
        "description": "Numbers / constants"
      },
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#EBC88D"
      }
    },
    {
      "metadata": {
        "description": "Keywords"
      },
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#82D2CE"
      }
    },
    {
      "metadata": {
        "description": "Operators"
      },
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#E0E1E4"
      }
    },
    {
      "metadata": {
        "description": "Functions"
      },
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#EBC88D"
      }
    },
    {
      "metadata": {
        "description": "Classes / types"
      },
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "support.class",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#87C3FF"
      }
    },
    {
      "metadata": {
        "description": "Properties / fields"
      },
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#AF9CFF"
      }
    },
    {
      "metadata": {
        "description": "Variables"
      },
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#E0E1E4"
      }
    },
    {
      "metadata": {
        "description": "Constants / enums"
      },
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant"
      ],
      "settings": {
        "foreground": "#AF9CFF"
      }
    },
    {
      "metadata": {
        "description": "Decorators / annotations / metadata"
      },
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator",
        "meta.annotation",
        "punctuation.definition.annotation",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#A8CC7C"
      }
    },
    {
      "metadata": {
        "description": "Tags"
      },
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
